<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".app.MyApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Utanglog"
        tools:targetApi="31">

        <!-- Login Activity - LAUNCHER -->
        <activity
            android:name=".screens.login.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Register Activity -->
        <activity
            android:name=".screens.register.RegisterActivity"
            android:exported="false" />

        <!-- DisplayDebt Activity - MUST match your folder name EXACTLY -->
        <activity
            android:name=".screens.displaydebt.DisplayDebtActivity"
            android:exported="false" />

        <!-- AddDebt Activity - MUST match your folder name EXACTLY -->
        <activity
            android:name=".screens.adddebt.AddDebtActivity"
            android:exported="false" />

        <!-- Profile Activity -->
        <activity
            android:name=".screens.profile.ProfileActivity"
            android:exported="false" />

        <!-- DebtDetail Activity -->
        <activity
            android:name=".screens.debtdetail.DebtDetailActivity"
            android:exported="false" />

    </application>

</manifest>