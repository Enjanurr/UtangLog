<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_screen">

    <!-- ============================================
         SCROLLVIEW (Takes remaining space above bottom nav)
         ============================================ -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="24dp">

            <!-- ============================================
                 HEADER SECTION
                 ============================================ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="28dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Profile"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_dark"
                    android:gravity="center"
                    android:letterSpacing="0.02" />

            </LinearLayout>

            <!-- ============================================
                 AVATAR SECTION WITH CAMERA OVERLAY
                 ============================================ -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/imageviewAvatar"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:src="@drawable/ic_person_placeholder"
                    android:background="@drawable/circle_background"
                    android:scaleType="centerCrop"
                    android:elevation="2dp"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- Camera Icon Overlay (Bottom Right) -->
                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="0dp"
                    android:layout_marginBottom="0dp"
                    android:background="@drawable/circle_camera_background"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_camera"
                        android:contentDescription="Change Photo" />

                </FrameLayout>

            </FrameLayout>

            <!-- ============================================
                 PROFILE INFORMATION CARD
                 ============================================ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- ============================================
                         NAME SECTION
                         ============================================ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="18dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Name"
                            android:textSize="12sp"
                            android:textColor="@color/gray_medium"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/textviewName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="John Doe"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/green_dark"
                            android:layout_marginTop="6dp" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1.5dp"
                        android:background="@color/gray_light"
                        android:layout_marginBottom="18dp" />

                    <!-- ============================================
                         EMAIL SECTION
                         ============================================ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="18dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Email"
                            android:textSize="12sp"
                            android:textColor="@color/gray_medium"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/textviewEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="john.doe@example.com"
                            android:textSize="16sp"
                            android:textColor="@color/green_dark"
                            android:layout_marginTop="6dp" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1.5dp"
                        android:background="@color/gray_light"
                        android:layout_marginBottom="18dp" />

                    <!-- ============================================
                         PHONE SECTION
                         ============================================ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Phone"
                            android:textSize="12sp"
                            android:textColor="@color/gray_medium"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/textviewPhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="+63 912 345 6789"
                            android:textSize="16sp"
                            android:textColor="@color/green_dark"
                            android:layout_marginTop="6dp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ============================================
                 ACTION BUTTONS SECTION
                 ============================================ -->
            <Button
                android:id="@+id/buttonEditProfile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                android:text="Edit Profile"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/button_background"
                android:elevation="2dp"
                android:translationZ="2dp"
                android:stateListAnimator="@null"
                app:backgroundTint="@null" />

            <!-- ============================================
                 LOGOUT BUTTON
                 ============================================ -->
            <Button
                android:id="@+id/buttonLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Logout"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/button_background"
                android:backgroundTint="#EF4444"
                android:elevation="2dp"
                android:translationZ="2dp"
                android:stateListAnimator="@null"
                app:backgroundTint="@null" />

        </LinearLayout>

    </ScrollView>

    <!-- ============================================
         BOTTOM NAVIGATION (Sticks to bottom)
         ============================================ -->
    <include
        android:id="@+id/bottomNavigation"
        layout="@layout/nav_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>