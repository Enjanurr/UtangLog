<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_screen">

    <!-- ============================================
         SCROLLVIEW (Takes remaining space above bottom nav)
         ============================================ -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="16dp">

            <!-- ============================================
                 HEADER SECTION
                 ============================================ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="28dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Add Debt"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_dark"
                    android:gravity="center"
                    android:letterSpacing="0.02" />

            </LinearLayout>

            <!-- ============================================
                 AVATAR SECTION
                 ============================================ -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="32dp">

                <!-- Profile Image - ID matches Activity -->
                <ImageView
                    android:id="@+id/imageviewDebtorAvatar"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:src="@drawable/ic_person_placeholder"
                    android:background="@drawable/circle_background"
                    android:scaleType="centerCrop"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="2dp" />

                <!-- Camera Icon Overlay (Bottom Right) -->
                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="0dp"
                    android:layout_marginBottom="0dp"
                    android:background="@drawable/circle_camera_background"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_camera"
                        android:contentDescription="Change Photo" />

                </FrameLayout>

            </FrameLayout>

            <!-- ============================================
                 NAME FIELD
                 ============================================ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Name"
                android:textSize="13sp"
                android:textColor="@color/green_dark"
                android:layout_marginBottom="6dp"
                android:letterSpacing="0.05"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edittextName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Enter name"
                android:textColorHint="@color/gray_hint"
                android:textColor="@color/black"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/edit_text_background"
                android:inputType="text"
                android:textSize="15sp"
                android:layout_marginBottom="16dp" />

            <!-- ============================================
                 AMOUNT FIELD
                 ============================================ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Amount"
                android:textSize="13sp"
                android:textColor="@color/green_dark"
                android:layout_marginBottom="6dp"
                android:letterSpacing="0.05"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edittextAmount"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Enter amount"
                android:textColorHint="@color/gray_hint"
                android:textColor="@color/black"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/edit_text_background"
                android:inputType="numberDecimal"
                android:textSize="15sp"
                android:layout_marginBottom="16dp" />

            <!-- ============================================
                 STATUS DROPDOWN
                 ============================================ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status"
                android:textSize="13sp"
                android:textColor="@color/green_dark"
                android:layout_marginBottom="6dp"
                android:letterSpacing="0.05"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerStatus"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/edit_text_background"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="16dp" />

            <!-- ============================================
                 DUE DATE FIELD
                 ============================================ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Due Date"
                android:textSize="13sp"
                android:textColor="@color/green_dark"
                android:layout_marginBottom="6dp"
                android:letterSpacing="0.05"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edittextDueDate"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="DD/MM/YYYY"
                android:textColorHint="@color/gray_hint"
                android:textColor="@color/black"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/edit_text_background"
                android:inputType="date"
                android:focusable="false"
                android:clickable="true"
                android:textSize="15sp"
                android:layout_marginBottom="16dp" />

            <!-- ============================================
                 ADDRESS FIELD
                 ============================================ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Address"
                android:textSize="13sp"
                android:textColor="@color/green_dark"
                android:layout_marginBottom="6dp"
                android:letterSpacing="0.05"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edittextAddress"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Enter address"
                android:textColorHint="@color/gray_hint"
                android:textColor="@color/black"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/edit_text_background"
                android:inputType="text"
                android:textSize="15sp"
                android:layout_marginBottom="24dp" />

            <!-- ============================================
                 SUBMIT BUTTON
                 ============================================ -->
            <Button
                android:id="@+id/btn_submit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="8dp"
                android:text="Add Debt"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/button_background"
                android:elevation="2dp"
                android:translationZ="2dp"
                android:stateListAnimator="@null"
                app:backgroundTint="@null" />

        </LinearLayout>

    </ScrollView>

    <!-- ============================================
         BOTTOM NAVIGATION (Sticks to bottom)
         ============================================ -->
    <include
        android:id="@+id/bottomNavigation"
        layout="@layout/nav_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>